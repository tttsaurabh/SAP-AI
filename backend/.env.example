# Application Settings
APP_NAME="SAP Knowledge AI Assistant"
DEBUG=true

# Security Settings
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Databases
DATABASE_URL="postgresql://sapadmin:sappassword@localhost:5432/sap_knowledge_db"
QDRANT_HOST="localhost"
QDRANT_PORT=6333
REDIS_URL="redis://localhost:6379/0"

# LLM Providers (At least one is required)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Ingestion Pipeline
UPLOADS_DIR="./uploads"
OCR_ENABLED=true
EMBEDDING_MODEL="local:sentence-transformers/all-MiniLM-L6-v2" # Can also be 'openai:text-embedding-3-large' or 'gemini:text-embedding-004'
RERANK_ENABLED=true
RERANK_MODEL="BAAI/bge-reranker-base"
