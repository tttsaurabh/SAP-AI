# Application Settings
APP_NAME="SAP Knowledge AI Assistant"
DEBUG=true

# Security Settings
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Databases
# For local dev: DATABASE_URL="sqlite:///./sap_knowledge.db"
# For Render deployment: Use the Supabase IPv4 connection pooler instead of direct host db.*.supabase.co
# Pooler Host format: aws-0-[region].pooler.supabase.com (port 6543, transaction pooling)
# Pooler User format: [db_user].[project_ref]
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/[dbname]?sslmode=require"
SUPABASE_DB_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/[dbname]?sslmode=require"

QDRANT_HOST="localhost"
QDRANT_PORT=6333
REDIS_URL="redis://localhost:6379/0"

# LLM Providers (At least one is required)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

GEMINI_MODEL="gemini-3.1-flash-lite"
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
LLM_TIMEOUT_SECONDS=10.0

# Ingestion Pipeline
UPLOADS_DIR="./uploads"
OCR_ENABLED=true
EMBEDDING_MODEL="local:sentence-transformers/all-MiniLM-L6-v2" # Can also be 'openai:text-embedding-3-large' or 'gemini:text-embedding-004'
RERANK_ENABLED=true
RERANK_MODEL="BAAI/bge-reranker-base"
